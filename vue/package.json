{
  "name": "@truenine/vue",
  "type": "module",
  "version": "2026.10107.100",
  "description": "vue 开发工具包",
  "author": "TrueNine",
  "license": "LGPL-2.1-or-later",
  "keywords": [
    "vue",
    "compose",
    "tool"
  ],
  "exports": {
    ".": "./dist/index.js",
