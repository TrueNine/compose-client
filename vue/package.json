  "peerDependencies": {
    "@truenine/types": "workspace:^",
    "vue": "catalog:vue"
  },
  "dependencies": {
    "@truenine/types": "workspace:^",
    "typescript": "catalog:",
    "vue": "catalog:vue"
  },
  "devDependencies": {
    "@truenine/config-vite": "workspace:^",
    "@truenine/eslint10-config": "workspace:^",
    "@truenine/tsconfig": "workspace:^"
  }
}
